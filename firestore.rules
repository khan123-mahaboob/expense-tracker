rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: userId (auth.uid)
    // Fields:
    //   - uid: string (required)
    //   - username: string (required)
    //   - email: string (required)
    //   - monthlySalary: number (required)
    //   - savingsGoal: number (required)
    //
    // Collection: transactions
    // Document ID: auto-generated
    // Fields:
    //   - userId: string (required)
    //   - type: string (required, ['income', 'expense', 'savings'])
    //   - amount: number (required, positive)
    //   - category: string (required)
    //   - description: string (optional)
    //   - date: timestamp (required)
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'username', 'email', 'monthlySalary', 'savingsGoal']) &&
             data.uid is string && data.uid == request.auth.uid &&
             data.username is string && data.username.size() > 0 && data.username.size() < 50 &&
             data.email is string &&
             data.monthlySalary is number && data.monthlySalary >= 0 &&
             data.savingsGoal is number && data.savingsGoal >= 0;
    }

    function isValidTransaction(data) {
      return data.keys().hasAll(['userId', 'type', 'amount', 'category', 'date']) &&
             data.userId == request.auth.uid &&
             data.type in ['income', 'expense', 'savings'] &&
             data.amount is number && data.amount > 0 &&
             data.category is string && data.category.size() > 0 &&
             data.date is string; // We use ISO string in the app
    }

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data);
    }

    match /transactions/{transactionId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && isValidTransaction(request.resource.data);
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid && isValidTransaction(request.resource.data);
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    match /test/connection {
      allow read: if true;
    }
  }
}
